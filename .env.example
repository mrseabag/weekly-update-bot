# Copy this file to .env and fill in your values
# bot.py loads this automatically via python-dotenv — no need to source it manually

# Only needed if hosting on PythonAnywhere's free tier (routes requests through their proxy)
HTTP_PROXY=http://proxy.server:3128
HTTPS_PROXY=http://proxy.server:3128

BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Manager's email — weekly Excel report goes here
MANAGER_EMAIL=boss@yourcompany.com

# Gmail account the bot sends FROM
SENDER_EMAIL=yourgmailaddress@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# How to get one: Google Account → Security → 2-Step Verification → App passwords
# Generate one for "Mail" on "Windows Computer"
SENDER_PASSWORD=xxxx xxxx xxxx xxxx
